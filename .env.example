# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used for links in transactional emails (defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional email. The provider is chosen in Admin → Settings → Email
# (app_settings table); EMAIL_PROVIDER is only the fallback when the DB is
# unreachable. Each provider dry-runs to the console when its own credentials
# are blank.
EMAIL_PROVIDER=gmail

# Gmail SMTP (App Password) — the default. Requires 2-Step Verification, then a
# 16-char App Password. MAIL_FROM (optional) sets the display name.
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM=

# Resend — set EMAIL_PROVIDER=resend and a verified domain in RESEND_FROM to use.
RESEND_API_KEY=
RESEND_FROM="rainbykello <onboarding@resend.dev>"

# Shared secret for Vercel Cron job authorization (Bearer token)
CRON_SECRET=

# Node
NODE_ENV=development

# Google Sheets sync (Plan 5). Omit to disable sync.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Rate limiting (Upstash Redis). Omit both to use the in-memory dev fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile. Omit secret to bypass verification in dev; omit public key to hide the widget.
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
